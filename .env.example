# ═══════════════════════════════════════════════════════════════
#   NEPAL THRIFT - ENVIRONMENT CONFIGURATION
#   Copy to .env:  copy .env.example .env
#   Everything below has safe local defaults; nothing is required
#   to run the app for a college demo. Add keys to enable real
#   AI / payment providers.
# ═══════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5001

# ── Security (CHANGE THESE FOR ANY REAL DEPLOYMENT) ───────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# First admin account (seeded on first run; password is Argon2-hashed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe!Admin2026

# ── Database ──────────────────────────────────────────────────
# Default is local SQLite; swap for Postgres in production.
DATABASE_URL=sqlite:///products.db

# ── File uploads ──────────────────────────────────────────────
MAX_UPLOAD_BYTES=5242880
# Optional CDN base (leave empty to serve images locally)
CDN_BASE_URL=

# ── 🤖 AI CHAT / RECOMMENDATIONS: Groq (FREE) ─────────────────
# Powers the outfit advisor chatbot + styling tips (optional).
# Get a free key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── 🔧 OPTIONAL: Gemini (advanced styling feedback) ───────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── 🎯 VIRTUAL TRY-ON: realistic AI (optional) ────────────────
# With a Replicate token you get realistic IDM-VTON/Kolors try-on.
# WITHOUT it, the app falls back to free smart-compositing locally.
# Get a token at: https://replicate.com
REPLICATE_API_TOKEN=

# ── 💳 PAYMENTS (Nepal) ───────────────────────────────────────
# Khalti — get sandbox keys at https://test-admin.khalti.com
KHALTI_SECRET_KEY=
KHALTI_PUBLIC_KEY=
# eSewa — sandbox defaults below work out of the box for testing
ESEWA_MERCHANT_CODE=EPAYTEST
PAYMENT_RETURN_URL=http://127.0.0.1:5001/payment/verify

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false

# ═══════════════════════════════════════════════════════════════
# SETUP:
# 1. copy .env.example .env
# 2. pip install -r requirements.txt
# 3. python app.py
# 4. Open http://127.0.0.1:5001  (admin: /admin/login)
# ═══════════════════════════════════════════════════════════════